# ===========================================
# MCQ Generator - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Mistral AI Configuration (REQUIRED)
# ===========================================
# Get your API key from: https://mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Model to use (options: mistral-small, mistral-medium, mistral-large)
MISTRAL_MODEL=mistral-medium

# Temperature for generation (0.0 = deterministic, 1.0 = creative)
MISTRAL_TEMPERATURE=0.6

# Maximum tokens in generated response
MISTRAL_MAX_TOKENS=128

# ===========================================
# Backend Server Configuration
# ===========================================
# Host address for the FastAPI server
BACKEND_HOST=127.0.0.1

# Port number for the FastAPI server
BACKEND_PORT=8000

# ===========================================
# File Upload Configuration
# ===========================================
# Maximum file upload size in MB
MAX_FILE_SIZE=25

# ===========================================
# Cache Configuration
# ===========================================
# Cache timeout in seconds (3600 = 1 hour)
CACHE_TIMEOUT=3600

# ===========================================
# Logging Configuration
# ===========================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===========================================
# Optional: Advanced Settings
# ===========================================
# These are hardcoded in langchain_core.py but can be made configurable

# Text chunk size for document splitting
# CHUNK_SIZE=800

# Overlap between chunks
# CHUNK_OVERLAP=100

# Number of chunks to retrieve for context
# VECTOR_SEARCH_K=4

# Initial fetch count for MMR (Maximal Marginal Relevance)
# VECTOR_SEARCH_FETCH_K=10

# MMR diversity parameter (0.0 = diverse, 1.0 = similar)
# VECTOR_SEARCH_LAMBDA=0.5

# Minimum similarity score for distractors (0.0-1.0)
# SIMILARITY_MIN=0.3

# Maximum similarity score for distractors (0.0-1.0)
# SIMILARITY_MAX=0.75

# Minimum number of distractors per question
# MIN_DISTRACTORS=3
